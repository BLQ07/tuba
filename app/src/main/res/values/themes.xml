    <style name="Theme.Truba.Green" parent="Theme.Truba">
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryVariant">@color/accent_green</item>
        <item name="colorSecondary">@color/accent_green</item>
    </style>

    <style name="Theme.Truba.Orange" parent="Theme.Truba">
        <item name="colorPrimary">@color/accent_orange</item>
        <item name="colorPrimaryVariant">@color/accent_orange</item>
